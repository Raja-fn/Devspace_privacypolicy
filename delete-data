<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Delete My Data — DevSpace</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --lime: #b8ff57;
    --ink: #0a0a0f;
    --ink2: #111118;
    --muted: #2a2a38;
    --text: #e8e8f0;
    --sub: #7a7a99;
    --orange: #ffaa40;
    --orange-dim: #2a1a00;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--ink);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(184,255,87,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(184,255,87,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
    padding: 64px 24px 80px;
  }

  .logo {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: var(--lime);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 56px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .logo::before {
    content: '';
    width: 8px; height: 8px;
    background: var(--lime);
    border-radius: 50%;
    display: inline-block;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--orange-dim);
    border: 1px solid var(--orange);
    color: var(--orange);
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    padding: 5px 12px;
    border-radius: 4px;
    margin-bottom: 20px;
  }

  h1 {
    font-family: 'Space Mono', monospace;
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 16px;
  }
  h1 span { color: var(--lime); }

  .subtitle {
    font-size: 16px;
    color: var(--sub);
    line-height: 1.7;
    margin-bottom: 48px;
    font-weight: 300;
  }

  /* Info note */
  .info-box {
    background: rgba(184,255,87,0.05);
    border: 1px solid rgba(184,255,87,0.2);
    border-radius: 12px;
    padding: 20px 24px;
    margin-bottom: 32px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .info-box p { font-size: 14px; color: #b0d88a; line-height: 1.6; }
  .info-icon { font-size: 18px; flex-shrink: 0; margin-top: 2px; }

  /* Data type selector */
  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--lime);
    letter-spacing: 0.12em;
    margin-bottom: 16px;
  }

  .data-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 32px;
  }

  .data-option {
    background: var(--ink2);
    border: 1px solid var(--muted);
    border-radius: 10px;
    padding: 16px 18px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    user-select: none;
  }
  .data-option:hover { border-color: rgba(184,255,87,0.3); }
  .data-option.selected {
    border-color: var(--lime);
    background: rgba(184,255,87,0.06);
  }

  .checkbox {
    width: 18px; height: 18px;
    border: 1.5px solid var(--muted);
    border-radius: 4px;
    flex-shrink: 0;
    margin-top: 1px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
  }
  .data-option.selected .checkbox {
    background: var(--lime);
    border-color: var(--lime);
  }
  .checkbox::after {
    content: '';
    width: 5px; height: 9px;
    border: 2px solid var(--ink);
    border-top: none; border-left: none;
    transform: rotate(45deg) translateY(-1px);
    display: none;
  }
  .data-option.selected .checkbox::after { display: block; }

  .option-text strong {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 3px;
  }
  .option-text span {
    font-size: 12px;
    color: var(--sub);
    line-height: 1.4;
  }

  /* Form */
  .form-group {
    margin-bottom: 20px;
  }
  label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--sub);
    margin-bottom: 8px;
    letter-spacing: 0.02em;
  }
  input, textarea {
    width: 100%;
    background: var(--ink2);
    border: 1px solid var(--muted);
    border-radius: 8px;
    padding: 13px 16px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    transition: border-color 0.2s;
    outline: none;
    resize: none;
  }
  input:focus, textarea:focus {
    border-color: rgba(184,255,87,0.5);
  }
  input::placeholder, textarea::placeholder { color: var(--muted); }

  .submit-btn {
    width: 100%;
    background: var(--lime);
    color: var(--ink);
    border: none;
    border-radius: 8px;
    padding: 15px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 8px;
  }
  .submit-btn:hover {
    background: #caffaa;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(184,255,87,0.2);
  }
  .submit-btn:active { transform: translateY(0); }

  /* Success state */
  .success-msg {
    display: none;
    background: rgba(184,255,87,0.07);
    border: 1px solid rgba(184,255,87,0.3);
    border-radius: 12px;
    padding: 28px;
    text-align: center;
    margin-top: 20px;
  }
  .success-msg.show { display: block; }
  .success-msg h3 {
    font-family: 'Space Mono', monospace;
    color: var(--lime);
    font-size: 18px;
    margin-bottom: 10px;
  }
  .success-msg p { color: var(--sub); font-size: 14px; line-height: 1.6; }

  /* Timeline */
  .timeline {
    background: var(--ink2);
    border: 1px solid var(--muted);
    border-radius: 12px;
    padding: 28px 32px;
    margin-bottom: 32px;
  }
  .timeline h3 {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: var(--lime);
    letter-spacing: 0.1em;
    margin-bottom: 20px;
  }
  .t-row {
    display: flex;
    gap: 16px;
    padding: 10px 0;
    border-bottom: 1px solid var(--muted);
    font-size: 14px;
    align-items: center;
  }
  .t-row:last-child { border-bottom: none; }
  .t-day {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    color: var(--lime);
    min-width: 64px;
    flex-shrink: 0;
  }
  .t-desc { color: var(--sub); line-height: 1.5; }

  /* Divider */
  .divider {
    border: none;
    border-top: 1px solid var(--muted);
    margin: 32px 0;
  }

  .footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  .footer p { font-size: 12px; color: var(--sub); }
  .footer a { color: var(--lime); text-decoration: none; font-size: 12px; }

  @media (max-width: 480px) {
    .data-options { grid-template-columns: 1fr; }
    .container { padding: 40px 16px 60px; }
    .timeline { padding: 20px; }
  }
</style>
</head>
<body>
<div class="container">

  <div class="logo">DevSpace by ARKA Studios</div>

  <div class="tag">📦 Data Request</div>
  <h1>Delete My<br><span>Data</span></h1>
  <p class="subtitle">You can request deletion of specific data types without deleting your full DevSpace account. Select what you'd like removed below.</p>

  <div class="info-box">
    <div class="info-icon">💡</div>
    <p>This form is for <strong>partial data deletion</strong>. If you want to delete your entire account, visit the <a href="delete-account.html" style="color: var(--lime);">Delete Account page</a> instead.</p>
  </div>

  <!-- Data type checkboxes -->
  <div class="section-label">SELECT DATA TO DELETE</div>
  <div class="data-options">
    <div class="data-option" onclick="toggleOption(this)">
      <div class="checkbox"></div>
      <div class="option-text">
        <strong>Profile Photo</strong>
        <span>Remove your uploaded profile picture from our servers</span>
      </div>
    </div>
    <div class="data-option" onclick="toggleOption(this)">
      <div class="checkbox"></div>
      <div class="option-text">
        <strong>GitHub Connection</strong>
        <span>Unlink GitHub data synced to your profile</span>
      </div>
    </div>
    <div class="data-option" onclick="toggleOption(this)">
      <div class="checkbox"></div>
      <div class="option-text">
        <strong>Projects & Posts</strong>
        <span>Remove all project showcases you've published</span>
      </div>
    </div>
    <div class="data-option" onclick="toggleOption(this)">
      <div class="checkbox"></div>
      <div class="option-text">
        <strong>Uploaded Media</strong>
        <span>Delete project screenshots and media files</span>
      </div>
    </div>
    <div class="data-option" onclick="toggleOption(this)">
      <div class="checkbox"></div>
      <div class="option-text">
        <strong>Aura History</strong>
        <span>Reset your reputation score and activity log</span>
      </div>
    </div>
    <div class="data-option" onclick="toggleOption(this)">
      <div class="checkbox"></div>
      <div class="option-text">
        <strong>All Personal Data</strong>
        <span>Remove all identifiable data (keeps account shell)</span>
      </div>
    </div>
  </div>

  <!-- Form -->
  <div class="section-label">YOUR DETAILS</div>

  <div id="requestForm">
    <div class="form-group">
      <label>Registered email address *</label>
      <input type="email" id="email" placeholder="you@college.edu" required>
    </div>
    <div class="form-group">
      <label>DevSpace username (if known)</label>
      <input type="text" id="username" placeholder="@yourhandle">
    </div>
    <div class="form-group">
      <label>Additional notes</label>
      <textarea rows="3" id="notes" placeholder="Any specific details about your request..."></textarea>
    </div>
    <button class="submit-btn" onclick="submitRequest()">SUBMIT DATA DELETION REQUEST →</button>
  </div>

  <div class="success-msg" id="successMsg">
    <h3>✓ Request Received</h3>
    <p>We've received your data deletion request. Our team will process it and send a confirmation to your email within <strong>7 business days</strong>.</p>
  </div>

  <hr class="divider">

  <!-- Timeline -->
  <div class="timeline">
    <h3>WHAT HAPPENS NEXT</h3>
    <div class="t-row">
      <span class="t-day">Day 0</span>
      <span class="t-desc">You submit this form — we receive your request automatically via email</span>
    </div>
    <div class="t-row">
      <span class="t-day">Day 1–2</span>
      <span class="t-desc">Our team verifies your identity using the registered email address</span>
    </div>
    <div class="t-row">
      <span class="t-day">Day 3–7</span>
      <span class="t-desc">Selected data is permanently removed from Firebase and our servers</span>
    </div>
    <div class="t-row">
      <span class="t-day">Day 7</span>
      <span class="t-desc">Confirmation email sent to you with a summary of what was deleted</span>
    </div>
  </div>

  <div class="footer">
    <p>© 2025 ARKA Studios. All rights reserved.</p>
    <a href="privacy-policy.html">Privacy Policy →</a>
  </div>

</div>

<script>
  function toggleOption(el) {
    el.classList.toggle('selected');
  }

  function submitRequest() {
    const email = document.getElementById('email').value.trim();
    if (!email) { alert('Please enter your registered email address.'); return; }

    const selected = [...document.querySelectorAll('.data-option.selected')]
      .map(el => el.querySelector('strong').textContent);
    if (selected.length === 0) { alert('Please select at least one data type to delete.'); return; }

    const username = document.getElementById('username').value.trim();
    const notes = document.getElementById('notes').value.trim();

    const subject = encodeURIComponent('DevSpace — Data Deletion Request');
    const body = encodeURIComponent(
      `Data Deletion Request\n\nEmail: ${email}\nUsername: ${username || 'Not provided'}\n\nData to delete:\n${selected.map(s => '- ' + s).join('\n')}\n\nNotes:\n${notes || 'None'}`
    );

    window.location.href = `mailto:privacy@arkastudios.in?subject=${subject}&body=${body}`;

    document.getElementById('requestForm').style.display = 'none';
    document.getElementById('successMsg').classList.add('show');
  }
</script>
</body>
</html>
